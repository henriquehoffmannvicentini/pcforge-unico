###########################
# Environment Example File
###########################
# Copy this file to `.env` before running the project:
#   cp .env.example .env
# All values below work out of the box for local development.

# --- Database (MySQL container) ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=TechAcademy5
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword

# --- Backend DB connection (used by backend container) ---
DB_HOST=mysql
DB_PORT=3306
DB_NAME=TechAcademy5
DB_USER=root
DB_PASSWORD=rootpassword

# --- JWT ---
JWT_SECRET=pcforge_dev_secret_2026

# --- Frontend ---
REACT_APP_API_URL=https://pcforge.local/api

# --- Environment ---
NODE_ENV=development

# --- Optional (third-party integrations) ---
MERCADO_PAGO_ACCESS_TOKEN=
FRONTEND_URL=https://pcforge.local
APP_HOST=pcforge.local
