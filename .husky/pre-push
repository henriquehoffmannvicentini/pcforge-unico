#!/bin/sh
. "$(dirname "$0")/_/husky.sh"
echo "Running pre-push: backend tests"
cd TechAcademy5back || exit 1
npm test
RET=$?
if [ $RET -ne 0 ]; then
  echo "Backend tests failed (pre-push). Aborting push."
  exit $RET
fi

echo "Running pre-push: frontend E2E tests"
cd ../TechAcademy5front || exit 1
npm run test:e2e
RET=$?
if [ $RET -ne 0 ]; then
  echo "Frontend E2E tests failed (pre-push). Aborting push."
  exit $RET
fi
exit 0
