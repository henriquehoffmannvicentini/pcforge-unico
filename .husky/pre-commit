#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Run lint-staged to auto-fix and validate staged files before commit
npx --no-install lint-staged

echo "Running pre-commit: backend lint and tests"
cd TechAcademy5back || exit 1
npm run lint
RET=$?
if [ $RET -ne 0 ]; then
  echo "Lint failed (pre-commit). Aborting commit."
  exit $RET
fi
npm test
RET=$?
if [ $RET -ne 0 ]; then
  echo "Tests failed (pre-commit). Aborting commit."
  exit $RET
fi
exit 0
